      </dependency>
      <dependency>
        <groupId>com.google.api.grpc</groupId>
        <artifactId>grpc-google-iam-v2</artifactId>
        <version>1.61.1-SNAPSHOT</version><!-- {x-version-update:grpc-google-iam-v2:current} -->
      </dependency>
      <dependency>
        <groupId>com.google.api.grpc</groupId>
