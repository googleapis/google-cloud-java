  <!-- Skip java-iam when analyzing showcase test coverage on SonarCloud   -->
  <profiles>
    <profile>
      <id>showcase-sonar-analysis</id>
      <activation>
        <property>
          <name>enableShowcaseTestCoverage</name>
        </property>
      </activation>
      <properties>
        <sonar.skip>true</sonar.skip>
      </properties>
    </profile>
  </profiles>
</project>
